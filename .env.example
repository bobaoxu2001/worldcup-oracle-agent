# ─────────────────────────────────────────────────────────────────────────
# WorldCup Oracle Agent — environment variables
#
# EVERY variable here is OPTIONAL. With an empty .env the app runs fully:
#   • predictions, simulations and explanations are 100% deterministic
#   • predictions persist to an in-memory store (no database needed)
#   • explanations use the built-in deterministic generator (no LLM needed)
# Add keys to unlock the enhanced path. Missing/invalid keys never break it.
# ─────────────────────────────────────────────────────────────────────────

# App URL (used for absolute links / metadata). Defaults to localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB — agent memory (MongoDB Partner Track).
# If unset/unreachable, the app falls back to an in-process memory store.
MONGODB_URI=
MONGODB_DB=worldcup_oracle

# Google Gemini — optional narrative polish (Google Cloud Rapid Agent track).
# If unset, the deterministic explanation generator is used instead.
GOOGLE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# WorldCup Oracle Agent — environment variables
#
# EVERY variable here is OPTIONAL. With an empty .env the app runs fully:
#   • predictions, simulations and explanations are 100% deterministic
#   • predictions persist to an in-memory store (no database needed)
#   • explanations use the built-in deterministic generator (no LLM needed)
# Add keys to unlock the enhanced path. Missing/invalid keys never break it.
# ─────────────────────────────────────────────────────────────────────────

# App URL (used for absolute links / metadata). Defaults to localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: protect /api/news/refresh. When set, the route requires
# "Authorization: Bearer <CRON_SECRET>". Vercel Cron sends this header
# automatically when the env var exists, so the daily refresh keeps working;
# manual refreshes must supply the same bearer token. Unset = route stays open.
CRON_SECRET=

# MongoDB — agent memory (MongoDB Partner Track).
# If unset/unreachable, the app falls back to an in-process memory store.
MONGODB_URI=
MONGODB_DB=worldcup_oracle

# Google Gemini — premium escalation provider in the cost-aware LLM router
# (complex/ambiguous queries + DeepSeek fallback) AND the driver of the Gemini
# function-calling agent loop (lib/llm/geminiAgent.ts — Gemini chooses which
# deterministic tools to call). Either var name works (GEMINI_API_KEY from AI
# Studio or GOOGLE_API_KEY). If unset, DeepSeek (then the deterministic
# generator) is used instead and the tool loop is simply off. GEMINI_MODEL is
# optional — defaults to a current model; override if Google retires it.
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Set to 0/off to force the Gemini function-calling tool loop off even with a key.
GEMINI_FUNCTION_CALLING=

# ── DeepSeek — optional hybrid LLM layer (ALL optional) ─────────────────────
# Active LLM in the production deploy: classifies ambiguous intent, writes the
# analyst narrative (structured result is its ONLY source of truth), and produces
# the Chinese answer. It never produces probabilities, news, injuries, or
# suspensions — those stay deterministic. If unset, the deterministic parser and
# templated explanations are used. Put the real key in .env.local / Vercel env —
# never commit it.
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Live tournament state (OPTIONAL — set EITHER provider) ─────────────────
# Real fixtures/results are the DETERMINISTIC source of truth for whether a team
# is eliminated — the LLM/news layers never decide elimination. Results are
# cached aggressively in MongoDB (free-tier friendly). If neither key is set,
# the app runs in demo mode (all teams active, clearly labelled) and never
# falsely claims a team is eliminated.
#
# Option A — API-Football / API-SPORTS (fixtures + standings + injuries).
# Optional overrides: API_FOOTBALL_LEAGUE_ID (default 1 = World Cup),
# API_FOOTBALL_SEASON (default 2026).
API_FOOTBALL_KEY=
# Option B — football-data.org (v4, X-Auth-Token; fixtures/results — no injuries
# on the free tier). Used when API_FOOTBALL_KEY is not set. Optional override:
# FOOTBALL_DATA_COMPETITION (default WC = FIFA World Cup).
FOOTBALL_DATA_API_KEY=

# ── Daily news intelligence (ALL optional) ─────────────────────────────────
# Article/news context ONLY (injuries/squad). NOT used to decide elimination.
# Configure ANY ONE of these to pull live team news. The first one set wins.
# If NONE is set, the agent uses curated demo signals (clearly labelled in the
# UI as "Demo news data"). Missing/invalid keys never break predictions.
NEWS_API_KEY=
GNEWS_API_KEY=
SERPAPI_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

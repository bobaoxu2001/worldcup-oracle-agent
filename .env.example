# ─────────────────────────────────────────────────────────────────────────
# WorldCup Oracle Agent — environment variables
#
# EVERY variable here is OPTIONAL. With an empty .env the app runs fully:
#   • predictions, simulations and explanations are 100% deterministic
#   • predictions persist to an in-memory store (no database needed)
#   • explanations use the built-in deterministic generator (no LLM needed)
# Add keys to unlock the enhanced path. Missing/invalid keys never break it.
# ─────────────────────────────────────────────────────────────────────────

# App URL (used for absolute links / metadata). Defaults to localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB — agent memory (MongoDB Partner Track).
# If unset/unreachable, the app falls back to an in-process memory store.
MONGODB_URI=
MONGODB_DB=worldcup_oracle

# Google Gemini — optional narrative polish (Google Cloud Rapid Agent track).
# If unset, the deterministic explanation generator is used instead.
GOOGLE_API_KEY=

# ── DeepSeek — optional LLM intent layer (ALL optional) ─────────────────────
# Used ONLY to classify intent (and, later, polish narratives). It never
# produces probabilities, news, injuries, or suspensions — those stay
# deterministic. If unset, the deterministic parser is used. Put the real key in
# .env.local / Vercel env — never commit it.
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Daily news intelligence (ALL optional) ─────────────────────────────────
# Configure ANY ONE of these to pull live team news. The first one set wins.
# If NONE is set, the agent uses curated demo signals (clearly labelled in the
# UI as "Demo news data"). Missing/invalid keys never break predictions.
NEWS_API_KEY=
GNEWS_API_KEY=
SERPAPI_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
